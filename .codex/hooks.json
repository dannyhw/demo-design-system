{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && bun run format",
            "timeout": 120,
            "statusMessage": "Formatting the codebase with Prettier"
          }
        ]
      }
    ]
  }
}
